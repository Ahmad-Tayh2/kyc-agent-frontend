{
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "tabWidth": 2,
  "overrides": [
    {
      "files": "*.js",
      "options": {
        "parser": "babel"
      }
    },
    {
      "files": [
        "*.mts",
        "*.cts",
        "*.ts"
      ],
      "options": {
        "parser": "babel-ts"
      }
    }
  ]
}
