import { Alert, AlertDescription } from '@/components/ui/alert';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardFooter, CardHeader, CardTitle } from '@/components/ui/card';
import { createWorldpaySession } from '@/services/worldpay';
import type { WorldpaySessionResponse } from '@/services/worldpay';
import type { PaymentData } from '@/types/payment';
import { Loader2 } from 'lucide-react';
import { useEffect, useState } from 'react';

interface WorldpayPaymentFormProps {
  transactionId?: number | string; // Allow string transaction references like "TR-74871798"
  paymentLinkToken?: string;
  amount: number;
  currency: string;
  description?: string;
  onSuccess: (paymentData: PaymentData) => void;
  onError: (error: string) => void;
}

type WorldpayFormStatus = 'idle' | 'loading' | 'ready' | 'redirecting' | 'error';

const WorldpayPaymentForm = ({
  transactionId,
  paymentLinkToken,
  amount,
  currency,
  description,
  onSuccess,
  onError,
}: WorldpayPaymentFormProps) => {
  const [status, setStatus] = useState<WorldpayFormStatus>('idle');
  const [errorMessage, setErrorMessage] = useState<string>('');
  const [sessionData, setSessionData] =
    useState<WorldpaySessionResponse | null>(null);

  // Create payment session on component mount
  useEffect(() => {
    const initializeWorldpay = async () => {
      try {
        setStatus('loading');

        console.log('Debug - transactionId:', transactionId);
        console.log('Debug - paymentLinkToken:', paymentLinkToken);

        if (!transactionId && !paymentLinkToken) {
          throw new Error('Transaction ID or payment link token is required');
        }

        // Use the transaction reference directly from the URL
        // It could be a string like "TR-74871798" or a numeric ID
        const requestData = transactionId
          ? { transactionReference: String(transactionId) } // Ensure it's a string
          : { paymentLinkToken };

        const session = await createWorldpaySession(requestData);
        setSessionData(session);
        setStatus('ready');
      } catch (error) {
        const message =
          error instanceof Error ? error.message : 'Failed to initialize payment';
        setErrorMessage(message);
        onError(message);
        setStatus('error');
      }
    };

    initializeWorldpay();
  }, [transactionId, paymentLinkToken, onError]);

  // Setup popup window for Worldpay payment
  useEffect(() => {
    if (status !== 'ready' || !sessionData) {
      return;
    }

    try {
      // Get the session URL from the response
      const { session_id: sessionUrl } = sessionData;
      
      console.log('Opening Worldpay session URL in new window:', sessionUrl);
      
      // Store transaction information in localStorage before redirecting
      // This will help us recover the payment details when user returns
      localStorage.setItem('worldpay_transaction', JSON.stringify({
        payment_id: sessionData.payment_id,
        transaction_uuid: sessionData.transaction_uuid,
        merchant_code: sessionData.merchant_code,
        amount,
        currency,
        description: description || '',
        timestamp: new Date().toISOString()
      }));
      
      // Method 1: Open in a popup window
      // const popup = window.open(sessionUrl, 'WorldpayPayment', 
      //   'width=800,height=700,resizable=yes,scrollbars=yes,status=yes');
      
      // if (!popup || popup.closed || typeof popup.closed === 'undefined') {
      //   throw new Error('Popup blocked by browser. Please allow popups for this site and try again.');
      // }
      
      // Method 2: Direct navigation with return URLs
      // Construct URL with return parameters
      const returnUrl = `${window.location.origin}${window.location.pathname}?worldpay_return=true`;
      
      // Generate the return URLs
      const successUrl = `${returnUrl}&status=success`;
      const cancelUrl = `${returnUrl}&status=cancel`;
      const failureUrl = `${returnUrl}&status=failure`;
      
      // Check if the URL already has query parameters
      const updatedSessionUrl = sessionUrl.includes('?') 
        ? `${sessionUrl}&successURL=${encodeURIComponent(successUrl)}&cancelURL=${encodeURIComponent(cancelUrl)}&failureURL=${encodeURIComponent(failureUrl)}`
        : `${sessionUrl}?successURL=${encodeURIComponent(successUrl)}&cancelURL=${encodeURIComponent(cancelUrl)}&failureURL=${encodeURIComponent(failureUrl)}`;
      
      // Redirect to Worldpay
      window.location.href = updatedSessionUrl;
    } catch (error) {
      console.error('Error opening Worldpay session:', error);
      setErrorMessage(error instanceof Error ? error.message : 'Failed to initialize payment session');
      setStatus('error');
      onError(error instanceof Error ? error.message : 'Failed to initialize payment session');
    }
  }, [status, sessionData, amount, currency, description, onSuccess, onError]);
  
  // Check if the user has been redirected back from Worldpay
  useEffect(() => {
    // Check for worldpay_return parameter in URL
    const searchParams = new URLSearchParams(window.location.search);
    const worldpayReturn = searchParams.get('worldpay_return');
    const returnStatus = searchParams.get('status');
    
    if (worldpayReturn === 'true') {
      // Retrieve transaction info from localStorage
      const storedTransaction = localStorage.getItem('worldpay_transaction');
      
      if (!storedTransaction) {
        setErrorMessage('Payment information not found. Please try again.');
        setStatus('error');
        onError('Payment information not found');
        return;
      }
      
      try {
        const transactionData = JSON.parse(storedTransaction);
        
        // Clear the stored transaction data
        localStorage.removeItem('worldpay_transaction');
        
        // Process based on status from URL
        if (returnStatus === 'success') {
          // Handle successful payment
          const now = new Date().toISOString();
          const paymentData: PaymentData = {
            id: typeof transactionData.payment_id === 'string' 
              ? parseInt(transactionData.payment_id) 
              : transactionData.payment_id,
            transaction_uuid: transactionData.transaction_uuid,
            provider_transaction_id: String(transactionData.payment_id),
            provider_payment_method: 'card',
            amount: transactionData.amount,
            currency: transactionData.currency,
            status: 'completed',
            type: 'payment',
            description: transactionData.description || '',
            provider: 'worldpay',
            processed_at: now,
            created_at: transactionData.timestamp || now,
            updated_at: now,
          };
          
          // Remove URL parameters
          const cleanUrl = window.location.pathname;
          window.history.replaceState({}, document.title, cleanUrl);
          
          onSuccess(paymentData);
        } else if (returnStatus === 'failure') {
          setErrorMessage('Payment failed. Please try again.');
          setStatus('error');
          onError('Payment failed');
          
          // Remove URL parameters
          const cleanUrl = window.location.pathname;
          window.history.replaceState({}, document.title, cleanUrl);
        } else if (returnStatus === 'cancel') {
          setErrorMessage('Payment was cancelled.');
          setStatus('error');
          onError('Payment cancelled');
          
          // Remove URL parameters
          const cleanUrl = window.location.pathname;
          window.history.replaceState({}, document.title, cleanUrl);
        }
      } catch (error) {
        console.error('Error processing Worldpay return:', error);
        setErrorMessage('Error processing payment return');
        setStatus('error');
        onError('Error processing payment return');
      }
    }
  }, [onSuccess, onError]);
    } catch (err) {
      const message = err instanceof Error 
        ? err.message 
        : 'Failed to initialize Worldpay payment frame';
      setErrorMessage(message);
      onError(message);
      setStatus('error');
    }
  }, [status, sessionData, onError, amount, currency, description, onSuccess]);

  // Handle retry after error
  const handleRetry = () => {
    setStatus('idle');
    setErrorMessage('');
    window.location.reload();
  };

  if (status === 'loading') {
    return (
      <div className='flex flex-col items-center justify-center p-6'>
        <Loader2 className='h-8 w-8 animate-spin text-blue-600 mb-4' />
        <p className='text-gray-600 text-center'>
          Initializing payment form...
        </p>
      </div>
    );
  }

  if (status === 'error') {
    return (
      <div className='space-y-4'>
        <Alert className='border-red-200 bg-red-50'>
          <AlertDescription className='text-red-700'>
            {errorMessage}
          </AlertDescription>
        </Alert>
        <Button
          onClick={handleRetry}
          className='w-full bg-blue-600 hover:bg-blue-700'
        >
          Retry Payment
        </Button>
      </div>
    );
  }

  return (
    <div className='worldpay-container relative'>
      {/* Card to display while redirecting to Worldpay */}
      <Card>
        <CardHeader>
          <CardTitle>Worldpay Payment</CardTitle>
          <CardDescription>
            You will be redirected to Worldpay to complete your payment.
          </CardDescription>
        </CardHeader>
        <CardContent className="flex items-center justify-center py-10">
          <Loader2 className='h-10 w-10 animate-spin text-blue-600' />
        </CardContent>
        <CardFooter className="flex justify-center">
          <p className="text-sm text-muted-foreground">
            Please do not close this window during the payment process.
          </p>
        </CardFooter>
      </Card>

      {/* Loading state while session initializes */}
      {status !== 'ready' && (
        <div className='absolute inset-0 flex items-center justify-center bg-white bg-opacity-80'>
          <Loader2 className='h-8 w-8 animate-spin text-blue-600' />
        </div>
      )}
    </div>
  );
};

export default WorldpayPaymentForm;
